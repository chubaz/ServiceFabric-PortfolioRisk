{
  "$id": "https://schemas.servicefabric.ai/risk/analytics/v0.1/scenario-shock.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "instrument_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Instrument Id",
      "type": "string"
    },
    "percentage_shock": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": -1.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Percentage Shock"
    }
  },
  "required": [
    "instrument_id",
    "percentage_shock"
  ],
  "title": "ScenarioShock",
  "type": "object"
}
