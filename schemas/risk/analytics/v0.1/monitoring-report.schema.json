{
  "$defs": {
    "MonitoringEvidence": {
      "additionalProperties": false,
      "description": "A publication-safe reference to retained local evidence.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "evidence_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "reference"
      ],
      "title": "MonitoringEvidence",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/analytics/v0.1/monitoring-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Digest"
    },
    "effects": {
      "default": [],
      "maxItems": 0,
      "minItems": 0,
      "title": "Effects",
      "type": "array"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/MonitoringEvidence"
      },
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "html": {
      "minLength": 1,
      "title": "Html",
      "type": "string"
    },
    "human_review_required": {
      "const": true,
      "default": true,
      "title": "Human Review Required",
      "type": "boolean"
    },
    "markdown": {
      "minLength": 1,
      "title": "Markdown",
      "type": "string"
    },
    "report_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Report Id",
      "type": "string"
    },
    "report_type": {
      "enum": [
        "monitoring",
        "monitoring_and_replay"
      ],
      "title": "Report Type",
      "type": "string"
    },
    "source_digest": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "title": "Source Digest",
      "type": "string"
    },
    "title": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "report_id",
    "report_type",
    "title",
    "source_digest",
    "markdown",
    "html",
    "evidence"
  ],
  "title": "MonitoringReport",
  "type": "object"
}
