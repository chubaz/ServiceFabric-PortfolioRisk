{
  "$id": "https://schemas.servicefabric.ai/risk/analytics/v0.1/return-observation.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "observed_at": {
      "format": "date-time",
      "title": "Observed At",
      "type": "string"
    },
    "value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Value"
    }
  },
  "required": [
    "observed_at",
    "value"
  ],
  "title": "ReturnObservation",
  "type": "object"
}
