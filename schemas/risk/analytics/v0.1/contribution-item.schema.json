{
  "$id": "https://schemas.servicefabric.ai/risk/analytics/v0.1/contribution-item.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contribution": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Contribution"
    },
    "instrument_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Instrument Id",
      "type": "string"
    },
    "instrument_return": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Instrument Return"
    },
    "weight": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Weight"
    }
  },
  "required": [
    "instrument_id",
    "weight"
  ],
  "title": "ContributionItem",
  "type": "object"
}
