{
  "$defs": {
    "MonitoringAgentStep": {
      "additionalProperties": false,
      "properties": {
        "capability_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Capability Id",
          "type": "string"
        },
        "completed_at": {
          "format": "date-time",
          "title": "Completed At",
          "type": "string"
        },
        "effects": {
          "default": [],
          "maxItems": 0,
          "minItems": 0,
          "title": "Effects",
          "type": "array"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "receipt": {
          "$ref": "#/$defs/MonitoringCapabilityReceipt"
        },
        "role": {
          "enum": [
            "risk.agent.market_data",
            "risk.agent.portfolio_exposure",
            "risk.agent.news_sentiment",
            "risk.agent.alert_recommendation"
          ],
          "title": "Role",
          "type": "string"
        },
        "sequence": {
          "maximum": 4,
          "minimum": 1,
          "title": "Sequence",
          "type": "integer"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "summary": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "sequence",
        "role",
        "capability_id",
        "started_at",
        "completed_at",
        "summary",
        "receipt"
      ],
      "title": "MonitoringAgentStep",
      "type": "object"
    },
    "MonitoringAlertDraft": {
      "additionalProperties": false,
      "properties": {
        "alert_id": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alert Id"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "effects": {
          "default": [],
          "maxItems": 0,
          "minItems": 0,
          "title": "Effects",
          "type": "array"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "human_review_required": {
          "const": true,
          "default": true,
          "title": "Human Review Required",
          "type": "boolean"
        },
        "instrument_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Instrument Ids",
          "type": "array"
        },
        "investment_advice": {
          "const": false,
          "default": false,
          "title": "Investment Advice",
          "type": "boolean"
        },
        "state": {
          "enum": [
            "draft",
            "no_breach",
            "abstained"
          ],
          "title": "State",
          "type": "string"
        },
        "suggested_next_steps": {
          "items": {
            "enum": [
              "continue_monitoring",
              "scenario_analysis",
              "further_review"
            ],
            "type": "string"
          },
          "title": "Suggested Next Steps",
          "type": "array"
        },
        "summary": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "state",
        "created_at",
        "summary",
        "suggested_next_steps",
        "evidence"
      ],
      "title": "MonitoringAlertDraft",
      "type": "object"
    },
    "MonitoringCapabilityReceipt": {
      "additionalProperties": false,
      "properties": {
        "capability_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Capability Id",
          "type": "string"
        },
        "effects": {
          "default": [],
          "maxItems": 0,
          "minItems": 0,
          "title": "Effects",
          "type": "array"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "input_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Input Digest",
          "type": "string"
        },
        "output_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Output Digest",
          "type": "string"
        },
        "status": {
          "enum": [
            "succeeded",
            "stopped"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "capability_id",
        "status",
        "input_digest",
        "output_digest",
        "evidence"
      ],
      "title": "MonitoringCapabilityReceipt",
      "type": "object"
    },
    "MonitoringEvidence": {
      "additionalProperties": false,
      "description": "A publication-safe reference to retained local evidence.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "evidence_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "reference"
      ],
      "title": "MonitoringEvidence",
      "type": "object"
    },
    "MonitoringEvidenceBundle": {
      "additionalProperties": false,
      "properties": {
        "assumptions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Assumptions",
          "type": "array"
        },
        "context_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Context Digest",
          "type": "string"
        },
        "dataset_revisions": {
          "items": {
            "maxLength": 256,
            "minLength": 1,
            "type": "string"
          },
          "title": "Dataset Revisions",
          "type": "array"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "policy_revision": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Policy Revision",
          "type": "string"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "context_digest",
        "policy_revision",
        "dataset_revisions",
        "evidence"
      ],
      "title": "MonitoringEvidenceBundle",
      "type": "object"
    },
    "MonitoringFinding": {
      "additionalProperties": false,
      "properties": {
        "assumptions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Assumptions",
          "type": "array"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "finding_id": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finding Id"
        },
        "finding_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Finding Type",
          "type": "string"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "high",
            "blocking"
          ],
          "title": "Severity",
          "type": "string"
        },
        "summary": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "finding_type",
        "severity",
        "summary",
        "evidence"
      ],
      "title": "MonitoringFinding",
      "type": "object"
    },
    "MonitoringFindingSet": {
      "additionalProperties": false,
      "properties": {
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "findings": {
          "items": {
            "$ref": "#/$defs/MonitoringFinding"
          },
          "title": "Findings",
          "type": "array"
        }
      },
      "required": [
        "findings"
      ],
      "title": "MonitoringFindingSet",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/contextual-monitoring-run.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "alert_draft": {
      "$ref": "#/$defs/MonitoringAlertDraft"
    },
    "as_of": {
      "format": "date-time",
      "title": "As Of",
      "type": "string"
    },
    "capability_receipts": {
      "items": {
        "$ref": "#/$defs/MonitoringCapabilityReceipt"
      },
      "minItems": 4,
      "title": "Capability Receipts",
      "type": "array"
    },
    "context_digest": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "title": "Context Digest",
      "type": "string"
    },
    "dataset_revisions": {
      "items": {
        "maxLength": 256,
        "minLength": 1,
        "type": "string"
      },
      "title": "Dataset Revisions",
      "type": "array"
    },
    "digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Digest"
    },
    "effects": {
      "default": [],
      "maxItems": 0,
      "minItems": 0,
      "title": "Effects",
      "type": "array"
    },
    "evidence_bundle": {
      "$ref": "#/$defs/MonitoringEvidenceBundle"
    },
    "findings": {
      "$ref": "#/$defs/MonitoringFindingSet"
    },
    "four_agent_timeline": {
      "items": {
        "$ref": "#/$defs/MonitoringAgentStep"
      },
      "maxItems": 4,
      "minItems": 4,
      "title": "Four Agent Timeline",
      "type": "array"
    },
    "human_review_required": {
      "const": true,
      "default": true,
      "title": "Human Review Required",
      "type": "boolean"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "policy_revision": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Policy Revision",
      "type": "string"
    },
    "run_at": {
      "format": "date-time",
      "title": "Run At",
      "type": "string"
    },
    "run_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "status": {
      "enum": [
        "succeeded",
        "stopped"
      ],
      "title": "Status",
      "type": "string"
    },
    "warnings": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "run_id",
    "status",
    "policy_revision",
    "context_digest",
    "run_at",
    "as_of",
    "dataset_revisions",
    "capability_receipts",
    "four_agent_timeline",
    "findings",
    "alert_draft",
    "evidence_bundle"
  ],
  "title": "ContextualMonitoringRun",
  "type": "object"
}
