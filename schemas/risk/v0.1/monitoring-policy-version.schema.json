{
  "$defs": {
    "MonitoringEvidence": {
      "additionalProperties": false,
      "description": "A publication-safe reference to retained local evidence.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "evidence_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "reference"
      ],
      "title": "MonitoringEvidence",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/monitoring-policy-version.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cadence": {
      "enum": [
        "manual",
        "daily",
        "weekly",
        "monthly"
      ],
      "title": "Cadence",
      "type": "string"
    },
    "cadence_metadata": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Cadence Metadata",
      "type": "string"
    },
    "concentration_threshold": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Concentration Threshold"
    },
    "daily_percentage_move_threshold": {
      "anyOf": [
        {
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Daily Percentage Move Threshold"
    },
    "digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Digest"
    },
    "event_relevance_minimum": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Event Relevance Minimum"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/MonitoringEvidence"
      },
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "historical_var_limit": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Historical Var Limit"
    },
    "human_review_required": {
      "const": true,
      "default": true,
      "title": "Human Review Required",
      "type": "boolean"
    },
    "negative_sentiment_threshold": {
      "anyOf": [
        {
          "maximum": 0.0,
          "minimum": -1.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Negative Sentiment Threshold"
    },
    "policy_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Policy Id",
      "type": "string"
    },
    "reviewed_at": {
      "format": "date-time",
      "title": "Reviewed At",
      "type": "string"
    },
    "reviewed_by": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Reviewed By",
      "type": "string"
    },
    "revision": {
      "anyOf": [
        {
          "pattern": "^policy:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Revision"
    },
    "scenario_loss_limit": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scenario Loss Limit"
    },
    "stale_data_maximum_age_seconds": {
      "minimum": 1,
      "title": "Stale Data Maximum Age Seconds",
      "type": "integer"
    },
    "version": {
      "minimum": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "policy_id",
    "version",
    "daily_percentage_move_threshold",
    "concentration_threshold",
    "event_relevance_minimum",
    "negative_sentiment_threshold",
    "stale_data_maximum_age_seconds",
    "cadence",
    "cadence_metadata",
    "reviewed_by",
    "reviewed_at",
    "evidence"
  ],
  "title": "MonitoringPolicyVersion",
  "type": "object"
}
