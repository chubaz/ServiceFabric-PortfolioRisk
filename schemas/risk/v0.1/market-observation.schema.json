{
  "$defs": {
    "QualityFlag": {
      "enum": [
        "complete",
        "partial",
        "missing",
        "stale",
        "estimated"
      ],
      "title": "QualityFlag",
      "type": "string"
    },
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "source_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Type",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "reference",
        "retrieved_at"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/market-observation.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "currency": {
      "pattern": "^[A-Z]{3}$",
      "title": "Currency",
      "type": "string"
    },
    "instrument_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Instrument Id",
      "type": "string"
    },
    "observed_at": {
      "format": "date-time",
      "title": "Observed At",
      "type": "string"
    },
    "price": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Price"
    },
    "quality_flags": {
      "default": [],
      "items": {
        "$ref": "#/$defs/QualityFlag"
      },
      "title": "Quality Flags",
      "type": "array"
    },
    "sources": {
      "default": [],
      "items": {
        "$ref": "#/$defs/SourceReference"
      },
      "title": "Sources",
      "type": "array"
    },
    "synthetic": {
      "title": "Synthetic",
      "type": "boolean"
    }
  },
  "required": [
    "instrument_id",
    "observed_at",
    "currency",
    "synthetic"
  ],
  "title": "MarketObservation",
  "type": "object"
}
