{
  "$defs": {
    "ContextQualityIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "dataset_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dataset Snapshot Id"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "message": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "severity": {
          "enum": [
            "warning",
            "blocking"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "ContextQualityIssue",
      "type": "object"
    },
    "DataVintageSelection": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "dataset_kind": {
          "enum": [
            "portfolio",
            "market",
            "fundamental",
            "crosswalk",
            "event"
          ],
          "title": "Dataset Kind",
          "type": "string"
        },
        "dataset_revision": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Revision",
          "type": "string"
        },
        "dataset_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Snapshot Id",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "selected_observation_count": {
          "minimum": 0,
          "title": "Selected Observation Count",
          "type": "integer"
        },
        "selection_rule": {
          "const": "available_at_lte_as_of",
          "default": "available_at_lte_as_of",
          "title": "Selection Rule",
          "type": "string"
        }
      },
      "required": [
        "dataset_kind",
        "dataset_snapshot_id",
        "dataset_revision",
        "retrieved_at",
        "as_of",
        "selected_observation_count",
        "evidence"
      ],
      "title": "DataVintageSelection",
      "type": "object"
    },
    "InstrumentDataBinding": {
      "additionalProperties": false,
      "properties": {
        "crosswalk_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Crosswalk Snapshot Id",
          "type": "string"
        },
        "effective_end": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective End"
        },
        "effective_start": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective Start"
        },
        "entity_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entity Id"
        },
        "evidence": {
          "default": [],
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "title": "Evidence",
          "type": "array"
        },
        "fundamental_entity_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fundamental Entity Id"
        },
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "mapping_rule": {
          "enum": [
            "exact_date_effective",
            "reviewed_primary",
            "none"
          ],
          "title": "Mapping Rule",
          "type": "string"
        },
        "state": {
          "enum": [
            "mapped",
            "unmapped",
            "ambiguous"
          ],
          "title": "State",
          "type": "string"
        }
      },
      "required": [
        "instrument_id",
        "state",
        "crosswalk_snapshot_id",
        "mapping_rule"
      ],
      "title": "InstrumentDataBinding",
      "type": "object"
    },
    "MappingCoverage": {
      "additionalProperties": false,
      "properties": {
        "ambiguous_count": {
          "minimum": 0,
          "title": "Ambiguous Count",
          "type": "integer"
        },
        "complete": {
          "title": "Complete",
          "type": "boolean"
        },
        "coverage": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Coverage"
        },
        "mapped_count": {
          "minimum": 0,
          "title": "Mapped Count",
          "type": "integer"
        },
        "position_count": {
          "minimum": 0,
          "title": "Position Count",
          "type": "integer"
        },
        "unmapped_count": {
          "minimum": 0,
          "title": "Unmapped Count",
          "type": "integer"
        }
      },
      "required": [
        "position_count",
        "mapped_count",
        "unmapped_count",
        "ambiguous_count",
        "coverage",
        "complete"
      ],
      "title": "MappingCoverage",
      "type": "object"
    },
    "MonitoringEventSignal": {
      "additionalProperties": false,
      "properties": {
        "amendment_state": {
          "enum": [
            "original",
            "amendment",
            "retraction"
          ],
          "title": "Amendment State",
          "type": "string"
        },
        "available_at": {
          "format": "date-time",
          "title": "Available At",
          "type": "string"
        },
        "entity_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Entity Id",
          "type": "string"
        },
        "event_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Event Id",
          "type": "string"
        },
        "event_time": {
          "format": "date-time",
          "title": "Event Time",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "novelty": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Novelty"
        },
        "relevance": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Relevance"
        },
        "sentiment": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": -1.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Sentiment"
        }
      },
      "required": [
        "event_id",
        "entity_id",
        "event_time",
        "available_at",
        "relevance",
        "sentiment",
        "novelty",
        "amendment_state",
        "evidence"
      ],
      "title": "MonitoringEventSignal",
      "type": "object"
    },
    "MonitoringEvidence": {
      "additionalProperties": false,
      "description": "A publication-safe reference to retained local evidence.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "evidence_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "reference"
      ],
      "title": "MonitoringEvidence",
      "type": "object"
    },
    "MonitoringMetric": {
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "metric": {
          "enum": [
            "daily_return",
            "volatility",
            "drawdown",
            "historical_var",
            "weight",
            "concentration",
            "scenario_loss",
            "contribution"
          ],
          "title": "Metric",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "metric",
        "value",
        "evidence"
      ],
      "title": "MonitoringMetric",
      "type": "object"
    },
    "MonitoringPolicyVersion": {
      "additionalProperties": false,
      "properties": {
        "cadence": {
          "enum": [
            "manual",
            "daily",
            "weekly",
            "monthly"
          ],
          "title": "Cadence",
          "type": "string"
        },
        "cadence_metadata": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Cadence Metadata",
          "type": "string"
        },
        "concentration_threshold": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Concentration Threshold"
        },
        "daily_percentage_move_threshold": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Daily Percentage Move Threshold"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "event_relevance_minimum": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Event Relevance Minimum"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "historical_var_limit": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Historical Var Limit"
        },
        "human_review_required": {
          "const": true,
          "default": true,
          "title": "Human Review Required",
          "type": "boolean"
        },
        "negative_sentiment_threshold": {
          "anyOf": [
            {
              "maximum": 0.0,
              "minimum": -1.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Negative Sentiment Threshold"
        },
        "policy_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Policy Id",
          "type": "string"
        },
        "reviewed_at": {
          "format": "date-time",
          "title": "Reviewed At",
          "type": "string"
        },
        "reviewed_by": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reviewed By",
          "type": "string"
        },
        "revision": {
          "anyOf": [
            {
              "pattern": "^policy:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revision"
        },
        "scenario_loss_limit": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scenario Loss Limit"
        },
        "stale_data_maximum_age_seconds": {
          "minimum": 1,
          "title": "Stale Data Maximum Age Seconds",
          "type": "integer"
        },
        "version": {
          "minimum": 1,
          "title": "Version",
          "type": "integer"
        }
      },
      "required": [
        "policy_id",
        "version",
        "daily_percentage_move_threshold",
        "concentration_threshold",
        "event_relevance_minimum",
        "negative_sentiment_threshold",
        "stale_data_maximum_age_seconds",
        "cadence",
        "cadence_metadata",
        "reviewed_by",
        "reviewed_at",
        "evidence"
      ],
      "title": "MonitoringPolicyVersion",
      "type": "object"
    },
    "PointInTimeObservation": {
      "additionalProperties": false,
      "description": "One local observation with separate observation and availability time.",
      "properties": {
        "available_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Available At"
        },
        "dataset_revision": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Revision",
          "type": "string"
        },
        "dataset_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Snapshot Id",
          "type": "string"
        },
        "entity_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Entity Id",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "field_name": {
          "default": "valuation_price",
          "maxLength": 256,
          "minLength": 1,
          "title": "Field Name",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "quality_flags": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "dataset_snapshot_id",
        "dataset_revision",
        "entity_id",
        "observed_at",
        "available_at",
        "retrieved_at",
        "evidence"
      ],
      "title": "PointInTimeObservation",
      "type": "object"
    },
    "PortfolioDataContext": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "assumptions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Assumptions",
          "type": "array"
        },
        "bindings": {
          "items": {
            "$ref": "#/$defs/InstrumentDataBinding"
          },
          "title": "Bindings",
          "type": "array"
        },
        "blocked": {
          "title": "Blocked",
          "type": "boolean"
        },
        "crosswalk_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Crosswalk Snapshot Id",
          "type": "string"
        },
        "data_vintages": {
          "items": {
            "$ref": "#/$defs/DataVintageSelection"
          },
          "title": "Data Vintages",
          "type": "array"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "event_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Snapshot Id"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "fundamental_dataset_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fundamental Dataset Snapshot Id"
        },
        "latest_fundamental_observations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PointInTimeObservation"
          },
          "title": "Latest Fundamental Observations",
          "type": "array"
        },
        "latest_market_observations": {
          "items": {
            "$ref": "#/$defs/PointInTimeObservation"
          },
          "title": "Latest Market Observations",
          "type": "array"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "mapping_coverage": {
          "$ref": "#/$defs/MappingCoverage"
        },
        "market_dataset_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Market Dataset Snapshot Id",
          "type": "string"
        },
        "portfolio_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Portfolio Snapshot Id",
          "type": "string"
        },
        "quality_issues": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ContextQualityIssue"
          },
          "title": "Quality Issues",
          "type": "array"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "portfolio_snapshot_id",
        "market_dataset_snapshot_id",
        "crosswalk_snapshot_id",
        "as_of",
        "bindings",
        "mapping_coverage",
        "data_vintages",
        "latest_market_observations",
        "evidence",
        "blocked"
      ],
      "title": "PortfolioDataContext",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/policy-evaluation-request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "context": {
      "$ref": "#/$defs/PortfolioDataContext"
    },
    "evaluated_at": {
      "format": "date-time",
      "title": "Evaluated At",
      "type": "string"
    },
    "evaluation_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Evaluation Id",
      "type": "string"
    },
    "events": {
      "default": [],
      "items": {
        "$ref": "#/$defs/MonitoringEventSignal"
      },
      "title": "Events",
      "type": "array"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/MonitoringEvidence"
      },
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "metrics": {
      "default": [],
      "items": {
        "$ref": "#/$defs/MonitoringMetric"
      },
      "title": "Metrics",
      "type": "array"
    },
    "policy_version": {
      "$ref": "#/$defs/MonitoringPolicyVersion"
    }
  },
  "required": [
    "evaluation_id",
    "policy_version",
    "context",
    "evaluated_at",
    "evidence"
  ],
  "title": "PolicyEvaluationRequest",
  "type": "object"
}
