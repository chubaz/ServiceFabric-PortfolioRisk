{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "description": "A content-addressed artifact available for evidence or snapshot lineage.",
      "properties": {
        "artifact_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Digest",
          "type": "string"
        },
        "media_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "digest",
        "media_type",
        "reference"
      ],
      "title": "ArtifactReference",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/news-event.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A time-bounded news event supported by retained evidence artifacts.",
  "properties": {
    "event_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Event Id",
      "type": "string"
    },
    "evidence_references": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "minItems": 1,
      "title": "Evidence References",
      "type": "array"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "summary": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "synthetic": {
      "title": "Synthetic",
      "type": "boolean"
    },
    "title": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "occurred_at",
    "title",
    "summary",
    "evidence_references",
    "synthetic"
  ],
  "title": "NewsEvent",
  "type": "object"
}
