{
  "$defs": {
    "ArtifactReference": {
      "additionalProperties": false,
      "description": "A content-addressed artifact available for evidence or snapshot lineage.",
      "properties": {
        "artifact_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Digest",
          "type": "string"
        },
        "media_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "digest",
        "media_type",
        "reference"
      ],
      "title": "ArtifactReference",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/risk-finding.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "An evidence-backed risk observation with a deterministic identifier.",
  "properties": {
    "assumptions": {
      "default": [],
      "items": {
        "maxLength": 256,
        "minLength": 1,
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "evidence_references": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "minItems": 1,
      "title": "Evidence References",
      "type": "array"
    },
    "finding_id": {
      "anyOf": [
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Finding Id"
    },
    "finding_type": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Finding Type",
      "type": "string"
    },
    "severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "snapshot_references": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "minItems": 1,
      "title": "Snapshot References",
      "type": "array"
    },
    "summary": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "title": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "warnings": {
      "default": [],
      "items": {
        "maxLength": 256,
        "minLength": 1,
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "finding_type",
    "severity",
    "title",
    "summary",
    "snapshot_references",
    "evidence_references"
  ],
  "title": "RiskFinding",
  "type": "object"
}
