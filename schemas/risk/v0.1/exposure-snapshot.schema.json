{
  "$defs": {
    "CashBalance": {
      "additionalProperties": false,
      "properties": {
        "amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Amount"
        },
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        }
      },
      "required": [
        "currency",
        "amount"
      ],
      "title": "CashBalance",
      "type": "object"
    },
    "ConcentrationMeasure": {
      "additionalProperties": false,
      "description": "A named Decimal concentration statistic for an exposure snapshot.",
      "properties": {
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "title": "ConcentrationMeasure",
      "type": "object"
    },
    "FundamentalObservation": {
      "additionalProperties": false,
      "properties": {
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "metric": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "quality_flags": {
          "default": [],
          "items": {
            "$ref": "#/$defs/QualityFlag"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Sources",
          "type": "array"
        },
        "synthetic": {
          "title": "Synthetic",
          "type": "boolean"
        },
        "unit": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "instrument_id",
        "metric",
        "observed_at",
        "unit",
        "synthetic"
      ],
      "title": "FundamentalObservation",
      "type": "object"
    },
    "MarketObservation": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Price"
        },
        "quality_flags": {
          "default": [],
          "items": {
            "$ref": "#/$defs/QualityFlag"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Sources",
          "type": "array"
        },
        "synthetic": {
          "title": "Synthetic",
          "type": "boolean"
        }
      },
      "required": [
        "instrument_id",
        "observed_at",
        "currency",
        "synthetic"
      ],
      "title": "MarketObservation",
      "type": "object"
    },
    "PortfolioSnapshot": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "base_currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Base Currency",
          "type": "string"
        },
        "cash_balances": {
          "default": [],
          "items": {
            "$ref": "#/$defs/CashBalance"
          },
          "title": "Cash Balances",
          "type": "array"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "fundamental_observations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/FundamentalObservation"
          },
          "title": "Fundamental Observations",
          "type": "array"
        },
        "market_observations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/MarketObservation"
          },
          "title": "Market Observations",
          "type": "array"
        },
        "positions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Position"
          },
          "title": "Positions",
          "type": "array"
        },
        "snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Snapshot Id",
          "type": "string"
        },
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Sources",
          "type": "array"
        }
      },
      "required": [
        "snapshot_id",
        "as_of",
        "base_currency"
      ],
      "title": "PortfolioSnapshot",
      "type": "object"
    },
    "Position": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "market_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Value"
        },
        "price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Price"
        },
        "quantity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        }
      },
      "required": [
        "instrument_id",
        "quantity",
        "price",
        "market_value",
        "currency"
      ],
      "title": "Position",
      "type": "object"
    },
    "PositionExposure": {
      "additionalProperties": false,
      "description": "A position market value and its signed share of portfolio NAV.",
      "properties": {
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "market_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Value"
        },
        "weight": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "description": "Signed market value divided by portfolio NAV, which includes cash.",
          "title": "Weight"
        }
      },
      "required": [
        "instrument_id",
        "market_value",
        "weight"
      ],
      "title": "PositionExposure",
      "type": "object"
    },
    "QualityFlag": {
      "enum": [
        "complete",
        "partial",
        "missing",
        "stale",
        "estimated"
      ],
      "title": "QualityFlag",
      "type": "string"
    },
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "source_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Type",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "reference",
        "retrieved_at"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/exposure-snapshot.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Immutable exposure calculation derived from exactly one portfolio snapshot.\n\nGross exposure is the sum of absolute position market values divided by NAV.\nNet exposure is the sum of signed position market values divided by NAV.\nCash is excluded from gross and net exposure but included in NAV and cash weight.",
  "properties": {
    "as_of": {
      "format": "date-time",
      "title": "As Of",
      "type": "string"
    },
    "cash_weight": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "description": "Total cash divided by NAV.",
      "title": "Cash Weight"
    },
    "concentration_measures": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ConcentrationMeasure"
      },
      "title": "Concentration Measures",
      "type": "array"
    },
    "digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Digest"
    },
    "gross_exposure": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "description": "Sum of absolute position market values divided by NAV; cash excluded.",
      "title": "Gross Exposure"
    },
    "largest_position_weight": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "description": "Largest absolute signed position weight; cash excluded.",
      "title": "Largest Position Weight"
    },
    "nav": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "description": "Portfolio NAV: positions plus cash, all in the portfolio base currency.",
      "title": "Nav"
    },
    "net_exposure": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "description": "Sum of signed position market values divided by NAV; cash excluded.",
      "title": "Net Exposure"
    },
    "portfolio_snapshot": {
      "$ref": "#/$defs/PortfolioSnapshot"
    },
    "position_exposures": {
      "items": {
        "$ref": "#/$defs/PositionExposure"
      },
      "title": "Position Exposures",
      "type": "array"
    },
    "snapshot_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Snapshot Id",
      "type": "string"
    }
  },
  "required": [
    "snapshot_id",
    "as_of",
    "portfolio_snapshot",
    "nav",
    "gross_exposure",
    "net_exposure",
    "largest_position_weight",
    "cash_weight",
    "position_exposures"
  ],
  "title": "ExposureSnapshot",
  "type": "object"
}
