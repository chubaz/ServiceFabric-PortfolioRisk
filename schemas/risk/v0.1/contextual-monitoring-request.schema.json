          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "human_review_required": {
          "const": true,
          "default": true,
          "title": "Human Review Required",
          "type": "boolean"
        },
        "instrument_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Instrument Ids",
          "type": "array"
        },
        "investment_advice": {
          "const": false,
          "default": false,
          "title": "Investment Advice",
          "type": "boolean"
        },
        "state": {
          "enum": [
            "draft",
            "no_breach",
            "abstained"
