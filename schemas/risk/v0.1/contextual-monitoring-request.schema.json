    "ContextQualityIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "dataset_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dataset Snapshot Id"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "message": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "severity": {
          "enum": [
            "warning",
            "blocking"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "ContextQualityIssue",
      "type": "object"
    },
    "DataVintageSelection": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "dataset_kind": {
          "enum": [
            "portfolio",
            "market",
            "fundamental",
            "crosswalk",
            "event"
          ],
          "title": "Dataset Kind",
          "type": "string"
        },
        "dataset_revision": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Revision",
          "type": "string"
        },
        "dataset_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Snapshot Id",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "selected_observation_count": {
          "minimum": 0,
          "title": "Selected Observation Count",
          "type": "integer"
        },
        "selection_rule": {
          "const": "available_at_lte_as_of",
          "default": "available_at_lte_as_of",
          "title": "Selection Rule",
          "type": "string"
        }
      },
      "required": [
        "dataset_kind",
        "dataset_snapshot_id",
        "dataset_revision",
        "retrieved_at",
        "as_of",
        "selected_observation_count",
        "evidence"
      ],
      "title": "DataVintageSelection",
      "type": "object"
    },
