{
  "$defs": {
    "CashBalance": {
      "additionalProperties": false,
      "properties": {
        "amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Amount"
        },
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        }
      },
      "required": [
        "currency",
        "amount"
      ],
      "title": "CashBalance",
      "type": "object"
    },
    "DateEffectiveMapping": {
      "additionalProperties": false,
      "description": "An explicit, date-effective stable-identifier link.",
      "properties": {
        "available_at": {
          "format": "date-time",
          "title": "Available At",
          "type": "string"
        },
        "crosswalk_dataset_revision": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Crosswalk Dataset Revision",
          "type": "string"
        },
        "crosswalk_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Crosswalk Snapshot Id",
          "type": "string"
        },
        "effective_end": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effective End"
        },
        "effective_start": {
          "format": "date",
          "title": "Effective Start",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "fundamental_entity_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fundamental Entity Id"
        },
        "open_ended": {
          "default": false,
          "title": "Open Ended",
          "type": "boolean"
        },
        "reviewed_primary": {
          "default": false,
          "title": "Reviewed Primary",
          "type": "boolean"
        },
        "source_instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Instrument Id",
          "type": "string"
        },
        "target_entity_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Target Entity Id",
          "type": "string"
        }
      },
      "required": [
        "crosswalk_snapshot_id",
        "crosswalk_dataset_revision",
        "source_instrument_id",
        "target_entity_id",
        "effective_start",
        "available_at",
        "evidence"
      ],
      "title": "DateEffectiveMapping",
      "type": "object"
    },
    "FundamentalObservation": {
      "additionalProperties": false,
      "properties": {
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "metric": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "quality_flags": {
          "default": [],
          "items": {
            "$ref": "#/$defs/QualityFlag"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Sources",
          "type": "array"
        },
        "synthetic": {
          "title": "Synthetic",
          "type": "boolean"
        },
        "unit": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "instrument_id",
        "metric",
        "observed_at",
        "unit",
        "synthetic"
      ],
      "title": "FundamentalObservation",
      "type": "object"
    },
    "MarketObservation": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Price"
        },
        "quality_flags": {
          "default": [],
          "items": {
            "$ref": "#/$defs/QualityFlag"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Sources",
          "type": "array"
        },
        "synthetic": {
          "title": "Synthetic",
          "type": "boolean"
        }
      },
      "required": [
        "instrument_id",
        "observed_at",
        "currency",
        "synthetic"
      ],
      "title": "MarketObservation",
      "type": "object"
    },
    "MonitoringEvidence": {
      "additionalProperties": false,
      "description": "A publication-safe reference to retained local evidence.",
      "properties": {
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "evidence_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Evidence Id",
          "type": "string"
        },
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "reference"
      ],
      "title": "MonitoringEvidence",
      "type": "object"
    },
    "PointInTimeObservation": {
      "additionalProperties": false,
      "description": "One local observation with separate observation and availability time.",
      "properties": {
        "available_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Available At"
        },
        "dataset_revision": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Revision",
          "type": "string"
        },
        "dataset_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Snapshot Id",
          "type": "string"
        },
        "entity_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Entity Id",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "field_name": {
          "default": "valuation_price",
          "maxLength": 256,
          "minLength": 1,
          "title": "Field Name",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "quality_flags": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Quality Flags",
          "type": "array"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        }
      },
      "required": [
        "dataset_snapshot_id",
        "dataset_revision",
        "entity_id",
        "observed_at",
        "available_at",
        "retrieved_at",
        "evidence"
      ],
      "title": "PointInTimeObservation",
      "type": "object"
    },
    "PortfolioSnapshot": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "base_currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Base Currency",
          "type": "string"
        },
        "cash_balances": {
          "default": [],
          "items": {
            "$ref": "#/$defs/CashBalance"
          },
          "title": "Cash Balances",
          "type": "array"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "fundamental_observations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/FundamentalObservation"
          },
          "title": "Fundamental Observations",
          "type": "array"
        },
        "market_observations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/MarketObservation"
          },
          "title": "Market Observations",
          "type": "array"
        },
        "positions": {
          "default": [],
          "items": {
            "$ref": "#/$defs/Position"
          },
          "title": "Positions",
          "type": "array"
        },
        "snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Snapshot Id",
          "type": "string"
        },
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Sources",
          "type": "array"
        }
      },
      "required": [
        "snapshot_id",
        "as_of",
        "base_currency"
      ],
      "title": "PortfolioSnapshot",
      "type": "object"
    },
    "Position": {
      "additionalProperties": false,
      "properties": {
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        },
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "market_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Market Value"
        },
        "price": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Price"
        },
        "quantity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Quantity"
        }
      },
      "required": [
        "instrument_id",
        "quantity",
        "price",
        "market_value",
        "currency"
      ],
      "title": "Position",
      "type": "object"
    },
    "QualityFlag": {
      "enum": [
        "complete",
        "partial",
        "missing",
        "stale",
        "estimated"
      ],
      "title": "QualityFlag",
      "type": "string"
    },
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "source_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Type",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "reference",
        "retrieved_at"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/portfolio-data-context-request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "as_of": {
      "format": "date-time",
      "title": "As Of",
      "type": "string"
    },
    "assumptions": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "crosswalk_dataset_revision": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Crosswalk Dataset Revision",
      "type": "string"
    },
    "crosswalk_records": {
      "items": {
        "$ref": "#/$defs/DateEffectiveMapping"
      },
      "title": "Crosswalk Records",
      "type": "array"
    },
    "crosswalk_retrieved_at": {
      "format": "date-time",
      "title": "Crosswalk Retrieved At",
      "type": "string"
    },
    "crosswalk_snapshot_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Crosswalk Snapshot Id",
      "type": "string"
    },
    "event_dataset_retrieved_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Event Dataset Retrieved At"
    },
    "event_dataset_revision": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Event Dataset Revision"
    },
    "event_snapshot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Event Snapshot Id"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/MonitoringEvidence"
      },
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "fundamental_dataset_retrieved_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fundamental Dataset Retrieved At"
    },
    "fundamental_dataset_revision": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fundamental Dataset Revision"
    },
    "fundamental_dataset_snapshot_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fundamental Dataset Snapshot Id"
    },
    "fundamental_observations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PointInTimeObservation"
      },
      "title": "Fundamental Observations",
      "type": "array"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "market_dataset_retrieved_at": {
      "format": "date-time",
      "title": "Market Dataset Retrieved At",
      "type": "string"
    },
    "market_dataset_revision": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Market Dataset Revision",
      "type": "string"
    },
    "market_dataset_snapshot_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Market Dataset Snapshot Id",
      "type": "string"
    },
    "market_observations": {
      "items": {
        "$ref": "#/$defs/PointInTimeObservation"
      },
      "title": "Market Observations",
      "type": "array"
    },
    "portfolio_snapshot": {
      "$ref": "#/$defs/PortfolioSnapshot"
    },
    "portfolio_snapshot_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Portfolio Snapshot Id",
      "type": "string"
    },
    "reviewed_primary_rule": {
      "anyOf": [
        {
          "const": "reviewed_primary=true",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reviewed Primary Rule"
    },
    "stale_data_maximum_age_seconds": {
      "minimum": 1,
      "title": "Stale Data Maximum Age Seconds",
      "type": "integer"
    }
  },
  "required": [
    "portfolio_snapshot_id",
    "portfolio_snapshot",
    "market_dataset_snapshot_id",
    "market_dataset_revision",
    "market_dataset_retrieved_at",
    "market_observations",
    "crosswalk_snapshot_id",
    "crosswalk_dataset_revision",
    "crosswalk_retrieved_at",
    "crosswalk_records",
    "as_of",
    "stale_data_maximum_age_seconds",
    "evidence"
  ],
  "title": "PortfolioDataContextRequest",
  "type": "object"
}
