          "default": null,
          "title": "Effective Start"
        },
        "entity_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entity Id"
        },
        "evidence": {
          "default": [],
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "title": "Evidence",
          "type": "array"
        },
        "fundamental_entity_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fundamental Entity Id"
        },
        "instrument_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Instrument Id",
          "type": "string"
        },
        "mapping_rule": {
          "enum": [
            "exact_date_effective",
            "reviewed_primary",
            "none"
          ],
          "title": "Mapping Rule",
          "type": "string"
        },
        "state": {
          "enum": [
            "mapped",
            "unmapped",
            "ambiguous"
          ],
          "title": "State",
          "type": "string"
        }
