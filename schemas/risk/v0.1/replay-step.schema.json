{
  "$defs": {
    "ContextQualityIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "dataset_snapshot_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dataset Snapshot Id"
        },
        "instrument_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instrument Id"
        },
        "message": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "severity": {
          "enum": [
            "warning",
            "blocking"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "ContextQualityIssue",
      "type": "object"
    },
    "ContextualMonitoringRun": {
      "additionalProperties": false,
      "properties": {
        "alert_draft": {
          "$ref": "#/$defs/MonitoringAlertDraft"
        },
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "capability_receipts": {
          "items": {
            "$ref": "#/$defs/MonitoringCapabilityReceipt"
          },
          "minItems": 4,
          "title": "Capability Receipts",
          "type": "array"
        },
        "context_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Context Digest",
          "type": "string"
        },
        "dataset_revisions": {
          "items": {
            "maxLength": 256,
            "minLength": 1,
            "type": "string"
          },
          "title": "Dataset Revisions",
          "type": "array"
        },
        "digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Digest"
        },
        "effects": {
          "default": [],
          "maxItems": 0,
          "minItems": 0,
          "title": "Effects",
          "type": "array"
        },
        "evidence_bundle": {
          "$ref": "#/$defs/MonitoringEvidenceBundle"
        },
        "findings": {
          "$ref": "#/$defs/MonitoringFindingSet"
        },
        "four_agent_timeline": {
          "items": {
            "$ref": "#/$defs/MonitoringAgentStep"
          },
          "maxItems": 4,
          "minItems": 4,
          "title": "Four Agent Timeline",
          "type": "array"
        },
        "human_review_required": {
          "const": true,
          "default": true,
          "title": "Human Review Required",
          "type": "boolean"
        },
        "limitations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "policy_revision": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Policy Revision",
          "type": "string"
        },
        "run_at": {
          "format": "date-time",
          "title": "Run At",
          "type": "string"
        },
        "run_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Run Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "succeeded",
            "stopped"
          ],
          "title": "Status",
          "type": "string"
        },
        "warnings": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "run_id",
        "status",
        "policy_revision",
        "context_digest",
        "run_at",
        "as_of",
        "dataset_revisions",
        "capability_receipts",
        "four_agent_timeline",
        "findings",
        "alert_draft",
        "evidence_bundle"
      ],
      "title": "ContextualMonitoringRun",
      "type": "object"
    },
    "DataVintageSelection": {
      "additionalProperties": false,
      "properties": {
        "as_of": {
          "format": "date-time",
          "title": "As Of",
          "type": "string"
        },
        "dataset_kind": {
          "enum": [
            "portfolio",
            "market",
            "fundamental",
            "crosswalk",
            "event"
          ],
          "title": "Dataset Kind",
          "type": "string"
        },
        "dataset_revision": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Revision",
          "type": "string"
        },
        "dataset_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Dataset Snapshot Id",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/MonitoringEvidence"
          },
          "minItems": 1,
          "title": "Evidence",
          "type": "array"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "selected_observation_count": {
          "minimum": 0,
          "title": "Selected Observation Count",
          "type": "integer"
        },
        "selection_rule": {
          "const": "available_at_lte_as_of",
          "default": "available_at_lte_as_of",
          "title": "Selection Rule",
          "type": "string"
        }
      },
      "required": [
        "dataset_kind",
        "dataset_snapshot_id",
        "dataset_revision",
        "retrieved_at",
        "as_of",
        "selected_observation_count",
        "evidence"
      ],
      "title": "DataVintageSelection",
      "type": "object"
    },
    "InstrumentDataBinding": {
      "additionalProperties": false,
      "properties": {
        "crosswalk_snapshot_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Crosswalk Snapshot Id",
