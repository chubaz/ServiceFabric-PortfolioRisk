{
  "$defs": {
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "source_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Type",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "reference",
        "retrieved_at"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/dataset-provenance.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Origin metadata retained with a dataset, including synthetic lineage.",
  "properties": {
    "sources": {
      "default": [],
      "items": {
        "$ref": "#/$defs/SourceReference"
      },
      "title": "Sources",
      "type": "array"
    },
    "synthetic": {
      "title": "Synthetic",
      "type": "boolean"
    },
    "synthetic_label": {
      "anyOf": [
        {
          "const": "synthetic",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Synthetic Label"
    },
    "synthetic_seed": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Synthetic Seed"
    }
  },
  "required": [
    "synthetic"
  ],
  "title": "DatasetProvenance",
  "type": "object"
}
