{
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/source-reference.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "reference": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Reference",
      "type": "string"
    },
    "retrieved_at": {
      "format": "date-time",
      "title": "Retrieved At",
      "type": "string"
    },
    "source_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Source Id",
      "type": "string"
    },
    "source_type": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Source Type",
      "type": "string"
    }
  },
  "required": [
    "source_id",
    "source_type",
    "reference",
    "retrieved_at"
  ],
  "title": "SourceReference",
  "type": "object"
}
