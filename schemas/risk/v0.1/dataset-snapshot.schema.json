{
  "$defs": {
    "DatasetFile": {
      "additionalProperties": false,
      "description": "A materialized dataset artifact referenced by an immutable snapshot.",
      "properties": {
        "digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Digest",
          "type": "string"
        },
        "media_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "row_count": {
          "minimum": 0,
          "title": "Row Count",
          "type": "integer"
        },
        "size": {
          "minimum": 0,
          "title": "Size",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "media_type",
        "size",
        "digest",
        "row_count"
      ],
      "title": "DatasetFile",
      "type": "object"
    },
    "DatasetProvenance": {
      "additionalProperties": false,
      "description": "Origin metadata retained with a dataset, including synthetic lineage.",
      "properties": {
        "sources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Sources",
          "type": "array"
        },
        "synthetic": {
          "title": "Synthetic",
          "type": "boolean"
        },
        "synthetic_label": {
          "anyOf": [
            {
              "const": "synthetic",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Synthetic Label"
        },
        "synthetic_seed": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Synthetic Seed"
        }
      },
      "required": [
        "synthetic"
      ],
      "title": "DatasetProvenance",
      "type": "object"
    },
    "SourceReference": {
      "additionalProperties": false,
      "properties": {
        "reference": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Reference",
          "type": "string"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "source_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Source Type",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "reference",
        "retrieved_at"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/risk/v0.1/dataset-snapshot.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Immutable dataset manifest linked to its ingestion runs and source queries.",
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Digest"
    },
    "files": {
      "items": {
        "$ref": "#/$defs/DatasetFile"
      },
      "title": "Files",
      "type": "array"
    },
    "ingestion_run_ids": {
      "items": {
        "maxLength": 256,
        "minLength": 1,
        "type": "string"
      },
      "title": "Ingestion Run Ids",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/DatasetProvenance"
    },
    "snapshot_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Snapshot Id",
      "type": "string"
    },
    "source_query_digests": {
      "items": {
        "type": "string"
      },
      "title": "Source Query Digests",
      "type": "array"
    }
  },
  "required": [
    "snapshot_id",
    "created_at",
    "files",
    "ingestion_run_ids",
    "source_query_digests",
    "provenance"
  ],
  "title": "DatasetSnapshot",
  "type": "object"
}
