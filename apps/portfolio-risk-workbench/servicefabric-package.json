{
  "application_id": "portfolio-risk-workbench",
  "version": "0.1.0",
  "framework": "fastapi",
  "adapter": "reviewed-fastapi-v1",
  "module": "app:app",
  "build": {
    "kind": "reviewed-python-source"
  },
  "start": {
    "adapter": "reviewed-fastapi-v1",
    "module": "app:app"
  },
  "health_path": "/health",
  "source_files": [
    {
      "path": "app.py",
      "sha256": "cd89e21aff16fc71405a2ce94b55832cd49365d05de63ac2388f6866092290e6"
    },
    {
      "path": "pyproject.toml",
      "sha256": "dd243eaccd4ab55b41a63e9ee15513760869f6b63bf3d79b7cf1c453d86eb37c"
    }
  ],
  "declared_resources": {
    "memory_mib": 128,
    "cpu_cores": 0.25,
    "storage_mib": 16,
    "network": "loopback-only"
  },
  "public_hosting": false,
  "entrypoints": [
    "web",
    "health",
    "capability-adapter"
  ],
  "capabilities": [
    {
      "tool_id": "risk.workbench.status",
      "path": "/actions/status"
    },
    {
      "tool_id": "planning.knowledge.list_due",
      "path": "/actions/planning-list-due"
    },
    {
      "tool_id": "data.synthetic.ingest",
      "path": "/actions/data-synthetic-ingest"
    },
    {
      "tool_id": "portfolio.snapshot.create",
      "path": "/actions/portfolio-snapshot-create"
    },
    {
      "tool_id": "portfolio.exposure.summarize",
      "path": "/actions/portfolio-exposure-summarize"
    },
    {
      "tool_id": "market.anomaly.detect",
      "path": "/actions/market-anomaly-detect"
    }
  ]
}
