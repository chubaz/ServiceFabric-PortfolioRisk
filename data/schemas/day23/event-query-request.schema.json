{
  "additionalProperties": false,
  "properties": {
    "as_of": {
      "format": "date-time",
      "title": "As Of",
      "type": "string"
    },
    "entity_ids": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Entity Ids",
      "type": "array"
    },
    "event_types": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Event Types",
      "type": "array"
    },
    "include_private_text": {
      "default": false,
      "title": "Include Private Text",
      "type": "boolean"
    },
    "limit": {
      "default": 100,
      "maximum": 1000,
      "minimum": 1,
      "title": "Limit",
      "type": "integer"
    },
    "minimum_relevance": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Minimum Relevance"
    },
    "snapshot_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Snapshot Id",
      "type": "string"
    }
  },
  "required": [
    "snapshot_id",
    "as_of"
  ],
  "title": "EventQueryRequest",
  "type": "object"
}
