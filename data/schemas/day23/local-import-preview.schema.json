{
  "$defs": {
    "DataQualityFlag": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "record_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Record Key"
        },
        "severity": {
          "enum": [
            "info",
            "warning",
            "blocking"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "DataQualityFlag",
      "type": "object"
    },
    "DataQualityMetric": {
      "additionalProperties": false,
      "properties": {
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "unit": {
          "default": "count",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "metric",
        "value"
      ],
      "title": "DataQualityMetric",
      "type": "object"
    },
    "DataQualityReport": {
      "additionalProperties": false,
      "properties": {
        "blocking": {
          "title": "Blocking",
          "type": "boolean"
        },
        "dataset_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Dataset Id",
          "type": "string"
        },
        "flags": {
          "default": [],
          "items": {
            "$ref": "#/$defs/DataQualityFlag"
          },
          "title": "Flags",
          "type": "array"
        },
        "metrics": {
          "items": {
            "$ref": "#/$defs/DataQualityMetric"
          },
          "title": "Metrics",
          "type": "array"
        },
        "report_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Report Id",
          "type": "string"
        },
        "source_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Source Digest",
          "type": "string"
        }
      },
      "required": [
        "report_id",
        "dataset_id",
        "source_digest",
        "metrics",
        "blocking"
      ],
      "title": "DataQualityReport",
      "type": "object"
    },
    "DatasetDefinition": {
      "additionalProperties": false,
      "properties": {
        "dataset_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Dataset Id",
          "type": "string"
        },
        "dataset_kind": {
          "enum": [
            "security_master",
            "daily_market",
            "fundamentals_annual",
            "identifier_crosswalk"
          ],
          "title": "Dataset Kind",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "provider_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Provider Id",
          "type": "string"
        }
      },
      "required": [
        "dataset_id",
        "provider_id",
        "dataset_kind",
        "description"
      ],
      "title": "DatasetDefinition",
      "type": "object"
    },
    "DatasetRevision": {
      "additionalProperties": false,
      "properties": {
        "dataset_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Dataset Id",
          "type": "string"
        },
        "retrieved_at": {
          "format": "date-time",
          "title": "Retrieved At",
          "type": "string"
        },
        "revision_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Revision Id",
          "type": "string"
        },
        "source_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Source Digest",
          "type": "string"
        }
      },
      "required": [
        "dataset_id",
        "revision_id",
        "retrieved_at",
        "source_digest"
      ],
      "title": "DatasetRevision",
      "type": "object"
    },
    "FieldDefinition": {
      "additionalProperties": false,
      "properties": {
        "data_type": {
          "enum": [
            "string",
            "integer",
            "decimal",
            "date",
            "datetime",
            "boolean"
          ],
          "title": "Data Type",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "field_name": {
          "title": "Field Name",
          "type": "string"
        },
        "nullable": {
          "default": true,
          "title": "Nullable",
          "type": "boolean"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "required": [
        "field_name",
        "data_type"
      ],
      "title": "FieldDefinition",
      "type": "object"
    },
    "FieldMapping": {
      "additionalProperties": false,
      "properties": {
        "data_type": {
          "enum": [
            "string",
            "integer",
            "decimal",
            "date",
            "datetime",
            "boolean"
          ],
          "title": "Data Type",
          "type": "string"
        },
        "nullable": {
          "default": true,
          "title": "Nullable",
          "type": "boolean"
        },
        "source_field": {
          "title": "Source Field",
          "type": "string"
        },
        "source_unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Unit"
        },
        "target_field": {
          "title": "Target Field",
          "type": "string"
        },
        "target_unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Unit"
        },
        "transformation_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Transformation Ids",
          "type": "array"
        }
      },
      "required": [
        "source_field",
        "target_field",
        "data_type"
      ],
      "title": "FieldMapping",
      "type": "object"
    },
    "LocalImportIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "row_number": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Row Number"
        },
        "severity": {
          "enum": [
            "warning",
            "blocking"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "LocalImportIssue",
      "type": "object"
    },
    "LocalMappingManifest": {
      "additionalProperties": false,
      "properties": {
        "dataset_kind": {
          "enum": [
            "security_master",
            "daily_market",
            "fundamentals_annual",
            "identifier_crosswalk"
          ],
          "title": "Dataset Kind",
          "type": "string"
        },
        "field_definitions": {
          "items": {
            "$ref": "#/$defs/FieldDefinition"
          },
          "title": "Field Definitions",
          "type": "array"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/FieldMapping"
          },
          "title": "Fields",
          "type": "array"
        },
        "key_fields": {
          "items": {
            "type": "string"
          },
          "title": "Key Fields",
          "type": "array"
        },
        "link_overlap_policy": {
          "default": "reject",
          "enum": [
            "reject",
            "latest_start"
          ],
          "title": "Link Overlap Policy",
          "type": "string"
        },
        "manifest_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Manifest Id",
          "type": "string"
        },
        "point_in_time_policy": {
          "$ref": "#/$defs/PointInTimePolicy"
        },
        "target_dataset": {
          "enum": [
            "security_master",
            "daily_market",
            "fundamentals_annual",
            "identifier_crosswalk"
          ],
          "title": "Target Dataset",
          "type": "string"
        },
        "transformations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/TransformationRecord"
          },
          "title": "Transformations",
          "type": "array"
        }
      },
      "required": [
        "manifest_id",
        "dataset_kind",
        "target_dataset",
        "fields",
        "field_definitions",
        "key_fields",
        "point_in_time_policy"
      ],
      "title": "LocalMappingManifest",
      "type": "object"
    },
    "PointInTimePolicy": {
      "additionalProperties": false,
      "properties": {
        "available_at_field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Available At Field"
        },
        "missing_available_at": {
          "default": "block",
          "enum": [
            "block",
            "warn"
          ],
          "title": "Missing Available At",
          "type": "string"
        },
        "observed_at_field": {
          "title": "Observed At Field",
          "type": "string"
        },
        "query_filter": {
          "const": "available_at_lte_as_of",
          "default": "available_at_lte_as_of",
          "title": "Query Filter",
          "type": "string"
        }
      },
      "required": [
        "observed_at_field",
        "available_at_field"
      ],
      "title": "PointInTimePolicy",
      "type": "object"
    },
    "ProviderAccessState": {
      "enum": [
        "available",
        "disabled"
      ],
      "title": "ProviderAccessState",
      "type": "string"
    },
    "ProviderDefinition": {
      "additionalProperties": false,
      "properties": {
        "access_state": {
          "$ref": "#/$defs/ProviderAccessState",
          "default": "available"
        },
        "credential_reference": {
          "anyOf": [
            {
              "pattern": "^secret-ref:[a-z0-9/_-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Credential Reference"
        },
        "display_name": {
          "title": "Display Name",
          "type": "string"
        },
        "network_enabled": {
          "const": false,
          "default": false,
          "title": "Network Enabled",
          "type": "boolean"
        },
        "profile": {
          "enum": [
            "synthetic_local",
            "licensed_local"
          ],
          "title": "Profile",
          "type": "string"
        },
        "provider_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Provider Id",
          "type": "string"
        }
      },
      "required": [
        "provider_id",
        "display_name",
        "profile"
      ],
      "title": "ProviderDefinition",
      "type": "object"
    },
    "PublicationRestriction": {
      "enum": [
        "synthetic_only",
        "internal_research_only",
        "no_publication"
      ],
      "title": "PublicationRestriction",
      "type": "string"
    },
    "RightsState": {
      "enum": [
        "reviewed_synthetic",
        "licensed_restricted"
      ],
      "title": "RightsState",
      "type": "string"
    },
    "SourceFileReference": {
      "additionalProperties": false,
      "properties": {
        "absolute_path": {
          "format": "path",
          "title": "Absolute Path",
          "type": "string"
        },
        "byte_count": {
          "minimum": 0,
          "title": "Byte Count",
          "type": "integer"
        },
        "file_format": {
          "enum": [
            "csv",
            "parquet"
          ],
          "title": "File Format",
          "type": "string"
        },
        "landing_path": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Landing Path"
        },
        "retained": {
          "default": false,
          "title": "Retained",
          "type": "boolean"
        },
        "source_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Source Digest",
          "type": "string"
        }
      },
      "required": [
        "absolute_path",
        "file_format",
        "source_digest",
        "byte_count"
      ],
      "title": "SourceFileReference",
      "type": "object"
    },
    "TransformationRecord": {
      "additionalProperties": false,
      "properties": {
        "disclosure": {
          "title": "Disclosure",
          "type": "string"
        },
        "operation": {
          "enum": [
            "identity",
            "absolute_value",
            "scale",
            "sign_normalization",
            "open_end_date"
          ],
          "title": "Operation",
          "type": "string"
        },
        "parameters": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Parameters",
          "type": "object"
        },
        "source_field": {
          "title": "Source Field",
          "type": "string"
        },
        "target_field": {
          "title": "Target Field",
          "type": "string"
        },
        "transformation_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Transformation Id",
          "type": "string"
        }
      },
      "required": [
        "transformation_id",
        "operation",
        "source_field",
        "target_field",
        "disclosure"
      ],
      "title": "TransformationRecord",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "accepted_row_count": {
      "minimum": 0,
      "title": "Accepted Row Count",
      "type": "integer"
    },
    "dataset": {
      "$ref": "#/$defs/DatasetDefinition"
    },
    "issues": {
      "default": [],
      "items": {
        "$ref": "#/$defs/LocalImportIssue"
      },
      "title": "Issues",
      "type": "array"
    },
    "mapping_digest": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "title": "Mapping Digest",
      "type": "string"
    },
    "mapping_manifest": {
      "$ref": "#/$defs/LocalMappingManifest"
    },
    "preview_digest": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "title": "Preview Digest",
      "type": "string"
    },
    "provider": {
      "$ref": "#/$defs/ProviderDefinition"
    },
    "publication_restriction": {
      "$ref": "#/$defs/PublicationRestriction"
    },
    "quality_report": {
      "$ref": "#/$defs/DataQualityReport"
    },
    "rejected_row_count": {
      "minimum": 0,
      "title": "Rejected Row Count",
      "type": "integer"
    },
    "retain_raw_source": {
      "default": false,
      "title": "Retain Raw Source",
      "type": "boolean"
    },
    "revision": {
      "$ref": "#/$defs/DatasetRevision"
    },
    "rights_state": {
      "$ref": "#/$defs/RightsState"
    },
    "row_count": {
      "minimum": 0,
      "title": "Row Count",
      "type": "integer"
    },
    "source": {
      "$ref": "#/$defs/SourceFileReference"
    },
    "source_schema": {
      "items": {
        "$ref": "#/$defs/FieldDefinition"
      },
      "title": "Source Schema",
      "type": "array"
    }
  },
  "required": [
    "preview_digest",
    "source",
    "provider",
    "dataset",
    "revision",
    "rights_state",
    "publication_restriction",
    "mapping_manifest",
    "mapping_digest",
    "source_schema",
    "row_count",
    "accepted_row_count",
    "rejected_row_count",
    "quality_report"
  ],
  "title": "LocalImportPreview",
  "type": "object"
}
